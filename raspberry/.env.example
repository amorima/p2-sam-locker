# --- Ligação ao backend SAM -------------------------------------------------
# Produção (atrás de Cloudflare): https://apisam.netdw.tech
# Backend local: http://127.0.0.1:3011
SAM_BACKEND_URL=https://apisam.netdw.tech
SAM_LOCKER_ID=1

# Chave interna dos dispositivos (= INTERNAL_API_KEY do backend).
SAM_INTERNAL_KEY=
SAM_USER_NIF=000000000
SAM_USER_ROLE=admin

# --- Comportamento ----------------------------------------------------------
SAM_PIN_LENGTH=6
SAM_DOOR_POLL_MS=250
SAM_DEPOSIT_TIMEOUT_S=120
SAM_SUCCESS_DWELL_S=5
SAM_HTTP_TIMEOUT=4

# --- Interface --------------------------------------------------------------
SAM_FULLSCREEN=1
SAM_HIDE_CURSOR=1
SAM_WINDOW_W=1024
SAM_WINDOW_H=600
# SAM_FONT=DejaVu Sans

# --- Modos de teste (sem hardware) ------------------------------------------
# DEMO_MODE: sem backend nem Arduino. PIN demo validado localmente;
# porta controlada pelo teclado ('o' = abrir, 'c' = fechar).
SAM_DEMO_MODE=0
SAM_DEMO_PIN=123456
SAM_DEMO_ITEM=Cobertor

# SIMULATE_DOOR: usa o backend para o PIN, mas simula a porta pelo teclado.
SAM_SIMULATE_DOOR=0
